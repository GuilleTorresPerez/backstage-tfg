server {
    listen 80;
    server_name localhost;
    root /usr/share/nginx/html;
    index index.html;

    # Gzip compresión para assets estáticos (rendimiento)
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;

    # SPA fallback: todas las rutas sirven index.html (enrutamiento Angular)
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Cacheo agresivo para assets hasheados (JS/CSS con hash en nombre)
    location ~* \.(?:css|js|woff2?|ttf|eot|otf|ico|png|jpg|jpeg|gif|svg|webp)$ {
        expires 1y;
        add_header Cache-Control "public, immutable" always;
        access_log off;
    }

    # --- Headers de seguridad (ENS / OWASP) ---
    # Aplicados con 'always' para que se incluyan incluso en respuestas de error.

    # HSTS: fuerza HTTPS durante 2 años, incluye subdominios
    # Documentación: https://nginx.org/en/docs/http/ngx_http_headers_module.html
    # OWASP: https://cheatsheetseries.owasp.org/cheatsheets/HTTP_Headers_Cheat_Sheet.html#strict-transport-security-hsts
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;

    # Previene clickjacking (frame embedding)
    # Aunque CSP frame-ancestors es más moderno, se mantiene por compatibilidad
    add_header X-Frame-Options "DENY" always;

    # Previene MIME-sniffing
    add_header X-Content-Type-Options "nosniff" always;

    # Controla la información de referrer enviada a otros sitios
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Deshabilita APIs del navegador no necesarias para reducir superficie de ataque
    # https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Permissions-Policy
    add_header Permissions-Policy "accelerometer=(), autoplay=(), camera=(), cross-origin-isolated=(), display-capture=(), encrypted-media=(), fullscreen=(), geolocation=(), gyroscope=(), keyboard-map=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), screen-wake-lock=(), sync-xhr=(self), usb=(), web-share=(), xr-spatial-tracking=()" always;

    # Aislamiento de contexto de navegación (previene XS-Leaks)
    # https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Cross-Origin-Opener-Policy
    add_header Cross-Origin-Opener-Policy "same-origin" always;

    # Controla qué recursos cross-origin pueden ser cargados
    add_header Cross-Origin-Embedder-Policy "require-corp" always;

    # Política de recurso cross-origin (protección contra Spectre/XSSI)
    add_header Cross-Origin-Resource-Policy "same-origin" always;

    # Control de DNS prefetch
    add_header X-DNS-Prefetch-Control "off" always;

    # Content Security Policy: restricción de fuentes de contenido
    # default-src 'self'  -> solo recursos del mismo origen
    # script-src 'self'   -> solo scripts propios (Angular build)
    # style-src 'self' 'unsafe-inline'  -> Angular puede usar estilos inline; se minimiza con hash en producción si es posible
    # img-src 'self' data:  -> imágenes propias y data URIs
    # font-src 'self'     -> fuentes propias
    # connect-src 'self' {{ values.apiBaseUrl }}  -> solo conexiones al backend configurado
    # frame-ancestors 'none'  -> no puede ser embebido (refuerzo anti-clickjacking)
    # base-uri 'self'     -> previene manipulación de <base>
    # form-action 'self'  -> formularios solo a orígenes propios
    # https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Content-Security-Policy
    add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' {{ values.apiBaseUrl }}; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" always;
}
